{
  "IntegrationMessaging": {
    "BatchSize": 100,
    "PollIntervalSeconds": 5,
    "LockDurationMinutes": 10,
    "EndpointCacheMinutes": 15,
    "StaleRequeueLimit": 200
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Error",
      "IntegrationMessaging": "Information",
      "IntegrationMessaging.Services.MessageProcessor": "Warning"
    }
  }
}
